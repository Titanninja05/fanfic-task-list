{
  "name": "Story",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Title of the fanfic"
    },
    "author": {
      "type": "string",
      "description": "Author of the fanfic"
    },
    "fandom": {
      "type": "string",
      "description": "Fandom the story belongs to"
    },
    "description": {
      "type": "string",
      "description": "Short summary of the story"
    },
    "cover_url": {
      "type": "string",
      "description": "URL of the cover image"
    },
    "total_chapters": {
      "type": "number",
      "description": "Total number of chapters"
    }
  },
  "required": [
    "title"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}
